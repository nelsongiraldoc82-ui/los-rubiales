// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Apartamentos del hotel rural Los Rubiales
model Apartment {
  id            String   @id @default(cuid())
  name          String   @unique // "Apartamento 1", "Apartamento 2", "Apartamento 3"
  description   String?
  capacity      Int      @default(6)
  registrations GuestRegistration[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// Registro de entrada (check-in) - un registro por cada grupo que llega
model GuestRegistration {
  id            String   @id @default(cuid())
  apartmentId   String
  apartment     Apartment @relation(fields: [apartmentId], references: [id], onDelete: Cascade)
  checkInDate   DateTime @default(now())
  checkOutDate  DateTime?
  guests        Guest[]
  status        String   @default("active") // active, checked_out
  notes         String?
  signature     String?  // Base64 de la firma digital del huésped principal
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([apartmentId])
  @@index([status])
}

// Datos de cada huésped (puede haber varios por registro)
model Guest {
  id             String   @id @default(cuid())
  registrationId String
  registration   GuestRegistration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  firstName      String
  lastName       String
  documentType   String   @default("DNI") // DNI, Pasaporte, NIE, etc.
  documentNumber String
  documentPhoto  String?  // Base64 de la foto del documento
  nationality    String?
  dateOfBirth    String?  // Formato ISO string para compatibilidad
  email          String?
  phone          String?
  address        String?
  city           String?
  postalCode     String?
  isMainGuest    Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([registrationId])
  @@index([documentNumber])
}
